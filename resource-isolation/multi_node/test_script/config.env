# =============================================================
# config.env  ─  Multi-node resource-isolation shared config
# source this file from every test script:
#   source "$(cd "$(dirname "$0")" && pwd)/../config.env"   (for preflight/)
#   source "$(cd "$(dirname "$0")" && pwd)/config.env"      (for test_script/)
# =============================================================

# ── Node: master ─────────────────────────────────────────────
MASTER_HOST="${MASTER_HOST:-10.231.178.130}"
MASTER_PORT="${MASTER_PORT:-2222}"
MASTER_USER="${MASTER_USER:-lge}"
MASTER_PASS="${MASTER_PASS:-lge123}"
MASTER_SUDO_PASS="${MASTER_SUDO_PASS:-${MASTER_PASS}}"

# ── Node: guest ──────────────────────────────────────────────
GUEST_HOST="${GUEST_HOST:-10.231.178.130}"
GUEST_PORT="${GUEST_PORT:-2221}"
GUEST_USER="${GUEST_USER:-lge}"
GUEST_PASS="${GUEST_PASS:-1234}"
GUEST_SUDO_PASS="${GUEST_SUDO_PASS:-${GUEST_PASS}}"

# ── Paths: master (remote) ───────────────────────────────────
MASTER_NUC_MASTER_DIR="${MASTER_NUC_MASTER_DIR:-/home/lge/work/demo/sdv-blueprint/resource-isolation/multi_node/nuc_master}"
MASTER_PULLPIRI_DIR="${MASTER_PULLPIRI_DIR:-/home/lge/work/demo/pullpiri}"
MASTER_TIMPANI_O_DIR="${MASTER_TIMPANI_O_DIR:-/home/lge/work/demo/TIMPANI/timpani-o/build}"
MASTER_TIMPANI_O_LOG="${MASTER_TIMPANI_O_LOG:-timpani-o.log}"
MASTER_ARDUINO_DIR="${MASTER_ARDUINO_DIR:-${MASTER_NUC_MASTER_DIR}/arduino}"
MASTER_SERIAL_DIR="${MASTER_SERIAL_DIR:-${MASTER_NUC_MASTER_DIR}/serial}"

# ── Paths: guest (remote) ────────────────────────────────────
GUEST_NUC_GUEST_DIR="${GUEST_NUC_GUEST_DIR:-/home/lge/work/demo/sdv-blueprint/resource-isolation/multi_node/nuc_guest}"
GUEST_MONITORING_DIR="${GUEST_MONITORING_DIR:-${GUEST_NUC_GUEST_DIR}/monitoring}"
GUEST_TIMPANI_N_DIR="${GUEST_TIMPANI_N_DIR:-/home/lge/work/demo/TIMPANI/timpani-n/build}"
GUEST_TIMPANI_N_LOG="${GUEST_TIMPANI_N_LOG:-timpani-n.log}"
GUEST_ARDUINO_DIR="${GUEST_ARDUINO_DIR:-${GUEST_NUC_GUEST_DIR}/arduino}"

# ── Pullpiri / TIMPANI ───────────────────────────────────────
NODE_CONFIG_YAML="${NODE_CONFIG_YAML:-/home/lge/work/demo/pullpiri/examples/resources/timpani/node_configurations.yaml}"

# ── Databroker ───────────────────────────────────────────────
DATABROKER_CONTAINER="${DATABROKER_CONTAINER:-failop-serial-bridge}"
DATABROKER_LOG_PATTERN="${DATABROKER_LOG_PATTERN:-[POST] http://192.168.0.3:47099/api/artifact yaml=container-launch.yaml status=200}"
DATABROKER_LOG_REGEX="${DATABROKER_LOG_REGEX:-api/artifact.*status=200}"
WAIT_LOG_TIMEOUT_SEC="${WAIT_LOG_TIMEOUT_SEC:-600}"

# ── SSH / Connection ─────────────────────────────────────────
USE_SSHPASS="${USE_SSHPASS:-auto}"
SSH_CONNECT_TIMEOUT_SEC="${SSH_CONNECT_TIMEOUT_SEC:-10}"
REMOTE_CMD_TIMEOUT_SEC="${REMOTE_CMD_TIMEOUT_SEC:-180}"

# ── Runtime flags ────────────────────────────────────────────
SKIP_ARDUINO="${SKIP_ARDUINO:-0}"
SKIP_IMAGE="${SKIP_IMAGE:-0}"
STEP7_FOREGROUND="${STEP7_FOREGROUND:-0}"
