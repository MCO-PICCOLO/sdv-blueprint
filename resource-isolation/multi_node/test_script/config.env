# =============================================================
# config.env  ─  Multi-node resource-isolation shared config
# source this file from every test script:
#   source "$(cd "$(dirname "$0")" && pwd)/../config.env"   (for preflight/)
#   source "$(cd "$(dirname "$0")" && pwd)/config.env"      (for test_script/)
# =============================================================

# #############################################################
# ★ USER SETTINGS (edit only this section)
# #############################################################

# ── Node connection info ────────────────────────────────────────────
# NOTE: All values below are REQUIRED. Fill them in before running any script.
#       (Leaving them empty makes the scripts abort — see the check block below.)
MASTER_HOST="${MASTER_HOST:-}"       # master SSH address
MASTER_PORT="${MASTER_PORT:-}"       # master SSH port
MASTER_USER="${MASTER_USER:-}"       # master account
MASTER_PASS="${MASTER_PASS:-}"       # master password
MASTER_NODE_IP="${MASTER_NODE_IP:-}" # master internal-network IP

GUEST_HOST="${GUEST_HOST:-}"         # guest SSH address
GUEST_PORT="${GUEST_PORT:-}"         # guest SSH port
GUEST_USER="${GUEST_USER:-}"         # guest account
GUEST_PASS="${GUEST_PASS:-}"         # guest password
GUEST_NODE_IP="${GUEST_NODE_IP:-}"   # guest internal-network IP

# ── Base paths ──────────────────────────────────────────────
# Set where sdv-blueprint's multi_node dir is located on each of master/guest.
MASTER_BASE_DIR="${MASTER_BASE_DIR:-}"
GUEST_BASE_DIR="${GUEST_BASE_DIR:-}"

# ── Required-value check ────────────────────────────────────
# Abort immediately if any required USER SETTING is left empty.
for __req in MASTER_HOST MASTER_PORT MASTER_USER MASTER_PASS MASTER_NODE_IP \
             GUEST_HOST GUEST_PORT GUEST_USER GUEST_PASS GUEST_NODE_IP \
             MASTER_BASE_DIR GUEST_BASE_DIR; do
    if [[ -z "${!__req:-}" ]]; then
        echo "[config.env] ERROR: required setting '${__req}' is empty. Edit config.env before running." >&2
        return 1 2>/dev/null || exit 1
    fi
done
unset __req

# #############################################################
# ▼ ADVANCED SETTINGS (no change needed when using defaults)
# #############################################################

# ── sudo password (default: same as login password) ────────────────
MASTER_SUDO_PASS="${MASTER_SUDO_PASS:-${MASTER_PASS}}"
GUEST_SUDO_PASS="${GUEST_SUDO_PASS:-${GUEST_PASS}}"

# ── Paths: master ─────────────────────────────────────────────
MASTER_TEST_SCRIPT_DIR="${MASTER_TEST_SCRIPT_DIR:-${MASTER_BASE_DIR}/test_script}"
MASTER_NUC_MASTER_DIR="${MASTER_NUC_MASTER_DIR:-${MASTER_BASE_DIR}/nuc_master}"
MASTER_ARDUINO_DIR="${MASTER_ARDUINO_DIR:-${MASTER_NUC_MASTER_DIR}/arduino}"
MASTER_SERIAL_BRIDGE_DIR="${MASTER_SERIAL_BRIDGE_DIR:-${MASTER_NUC_MASTER_DIR}/serial-bridge}"

# ── Paths: guest ──────────────────────────────────────────────
GUEST_TEST_SCRIPT_DIR="${GUEST_TEST_SCRIPT_DIR:-${GUEST_BASE_DIR}/test_script}"
GUEST_NUC_GUEST_DIR="${GUEST_NUC_GUEST_DIR:-${GUEST_BASE_DIR}/nuc_guest}"
GUEST_MONITORING_DIR="${GUEST_MONITORING_DIR:-${GUEST_NUC_GUEST_DIR}/monitoring}"
GUEST_ARDUINO_DIR="${GUEST_ARDUINO_DIR:-${GUEST_NUC_GUEST_DIR}/arduino}"

# ── Databroker log watch ─────────────────────────────────────
DATABROKER_CONTAINER="${DATABROKER_CONTAINER:-resiso-serial-bridge}"
DATABROKER_LOG_REGEX="${DATABROKER_LOG_REGEX:-api/artifact.*status=200}"
WAIT_LOG_TIMEOUT_SEC="${WAIT_LOG_TIMEOUT_SEC:-600}"

# ── SSH / connection ────────────────────────────────────────────────
USE_SSHPASS="${USE_SSHPASS:-auto}"
SSH_CONNECT_TIMEOUT_SEC="${SSH_CONNECT_TIMEOUT_SEC:-10}"
REMOTE_CMD_TIMEOUT_SEC="${REMOTE_CMD_TIMEOUT_SEC:-180}"