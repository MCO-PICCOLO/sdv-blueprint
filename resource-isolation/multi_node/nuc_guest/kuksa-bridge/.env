# Resource Isolation Guest Container Configuration

# KUKSA Databroker Configuration
# KUKSA_HOST: address of the master node that runs the KUKSA databroker.
# Leave empty: preflight/prepare_guest.sh auto-fills it before building the image
# (uses MASTER_NODE_IP from config.env, or the guest's default gateway = master).
KUKSA_HOST=
KUKSA_PORT=55556
KUKSA_PROTOCOL=grpc

# Trigger Script Configuration
# Toggle mode: ON script when button pressed, OFF script when pressed again
TRIGGER_ON_SCRIPT=/app/script/trigger-on.sh
TRIGGER_OFF_SCRIPT=/app/script/trigger-off.sh