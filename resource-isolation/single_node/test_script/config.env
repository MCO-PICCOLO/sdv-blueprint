# =============================================================
# config.env  ─  Single-node resource-isolation shared config
# source this file from every test script:
#   source "$(cd "$(dirname "$0")" && pwd)/config.env"      (for test_script/)
#
# Single-node: everything (pullpiri, nodeagent, timpani, monitoring,
# containers) runs locally on ONE machine. No SSH / no guest node.
# =============================================================

# #############################################################
# ★ USER SETTINGS (edit only this section)
# #############################################################

# ── Node identity ───────────────────────────────────────────────────
# NODE_NAME must match this machine's `hostname`, because the pullpiri
# nodeagent registers itself using the hostname and the workload YAMLs
# (serial-bridge/pullpiri-yaml/*.yaml) schedule onto this node name.
NODE_NAME="${NODE_NAME:-$(hostname)}"

# Local node IP used by pullpiri apiserver / nodeagent.
# Leave empty to auto-detect the first NIC address (loopback is avoided).
NODE_IP="${NODE_IP:-}"

# ── Base paths ──────────────────────────────────────────────
# Where sdv-blueprint single_node is located on this machine.
# REQUIRED: fill this in. Leaving it empty makes the scripts abort.
BASE_DIR="${BASE_DIR:-}"

# ── Required-value check ────────────────────────────────────
# Abort immediately if a required USER SETTING is left empty.
# (NODE_NAME defaults to the hostname; NODE_IP empty = auto-detect.)
for __req in BASE_DIR; do
    if [[ -z "${!__req:-}" ]]; then
        echo "[config.env] ERROR: required setting '${__req}' is empty. Edit config.env before running." >&2
        return 1 2>/dev/null || exit 1
    fi
done
unset __req

# #############################################################
# ▼ ADVANCED SETTINGS (no change needed when using defaults)
# #############################################################

# ── sudo password (used for local `sudo -S`) ────────────────────────
# Leave empty to use an interactive sudo prompt / passwordless sudo.
SUDO_PASS="${SUDO_PASS:-}"

# ── Paths ─────────────────────────────────────────────────────
TEST_SCRIPT_DIR="${TEST_SCRIPT_DIR:-${BASE_DIR}/test_script}"
MONITORING_DIR="${MONITORING_DIR:-${BASE_DIR}/monitoring}"
ARDUINO_DIR="${ARDUINO_DIR:-${BASE_DIR}/arduino}"
SERIAL_BRIDGE_DIR="${SERIAL_BRIDGE_DIR:-${BASE_DIR}/serial-bridge}"

# ── Databroker log watch ─────────────────────────────────────
DATABROKER_CONTAINER="${DATABROKER_CONTAINER:-resiso-serial-bridge}"
DATABROKER_LOG_REGEX="${DATABROKER_LOG_REGEX:-api/artifact.*status=200}"
WAIT_LOG_TIMEOUT_SEC="${WAIT_LOG_TIMEOUT_SEC:-600}"
