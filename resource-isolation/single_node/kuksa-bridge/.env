# Resource Isolation Single-Node Container Configuration
# All components run on the same host.

# KUKSA Databroker Configuration
# The databroker (docker) publishes port 55556 on the host. The kuksa-bridge
# container runs on the podman default bridge network, so it must reach the
# databroker via the host's LAN IP (not 127.0.0.1, which is the container itself).
# Leave KUKSA_HOST empty: preflight/prepare.sh auto-fills it with this host's
# detected IP (hostname -I) right before building the image.
KUKSA_HOST=192.168.0.3
KUKSA_PORT=55556
KUKSA_PROTOCOL=grpc

# Trigger Script Configuration
# Toggle mode: ON script when button pressed, OFF script when pressed again
TRIGGER_ON_SCRIPT=/app/script/trigger-on.sh
TRIGGER_OFF_SCRIPT=/app/script/trigger-off.sh

